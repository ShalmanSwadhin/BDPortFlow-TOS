{
  "name": "bdportflow",
  "version": "1.0.0",
  "description": "Chittagong Port Terminal Operating System - MERN Stack",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "cd server && npm run dev",
    "seed": "cd server && npm run seed",
    "install:all": "npm install && cd server && npm install",
    "start:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "keywords": [
    "port",
    "logistics",
    "terminal",
    "operating",
    "system",
    "mern"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
